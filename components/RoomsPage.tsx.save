import { useState, useEffect, useMemo } from "react";
import { useNavigate, useSearchParams } from "react-router-dom";
import { 
  Calendar as CalendarIcon, 
  Users, 
  MapPin, 
  Star, 
  Search, 
  Filter, 
  SlidersHorizontal,
  ChevronLeft,
  ArrowRight,
  Info,
  ShieldCheck,
  Zap,
  Check,
  ChevronDown
} from "lucide-react";
import { Button } from "@/components/ui/button";
import { Calendar } from "@/components/ui/calendar";
import { Card, CardContent } from "@/components/ui/card";
import { Popover, PopoverContent, PopoverTrigger } from "@/components/ui/popover";
import { Checkbox } from "@/components/ui/checkbox";
import { format } from "date-fns";
import { ar } from "date-fns/locale";
import { db, handleFirestoreError, OperationType } from "@/src/lib/firebase";
import { collection, onSnapshot, query, collectionGroup, getDocs } from "firebase/firestore";
import { cn } from "@/lib/utils";
import { motion, AnimatePresence } from "motion/react";

interface Hotel {
  id: string;
  name: string;
  description: string;
  images: string[];
  price: number;
  rating: number;
  location: string;
  city: string;
  amenities: string[];
  reviewsCount?: number;
}

export default function RoomsPage() {
  const navigate = useNavigate();
  const [searchParams, setSearchParams] = useSearchParams();
  
  const [date, setDate] = useState<{ from: Date | undefined; to: Date | undefined }>({
    from: searchParams.get("from") ? new Date(searchParams.get("from")!) : new Date(),
    to: searchParams.get("to") ? new Date(searchParams.get("to")!) : new Date(new Date().getTime() + 86400000 * 3),
  });
  
  const [destination, setDestination] = useState(searchParams.get("destination") || "");
  const [guestCount, setGuestCount] = useState(searchParams.get("guests") || "2 بالغين · 1 غرفة");
  
  const [hotels, setHotels] = useState<Hotel[]>([]);
  const [loading, setLoading] = useState(true);
  
  // Filters
  const [priceRange, setPriceRange] = useState<[number, number]>([0, 10000]);
  const [minRating, setMinRating] = useState(0);

  useEffect(() => {
    setLoading(true);
    const q = query(collectionGroup(db, 'hotels'));
    const unsubscribe = onSnapshot(q, (snapshot) => {
      const hotelsData = snapshot.docs.map(doc => {
        const data = doc.data();
        return {
          id: doc.id,
          ...data,
          images: Array.isArray(data.images) ? data.images : [data.image || "https://picsum.photos/seed/hotel/800/600"],
          amenities: Array.isArray(data.amenities) ? data.amenities : [],
          reviewsCount: data.reviewsCount || Math.floor(Math.random() * 500) + 100
        };
      }) as Hotel[];
      setHotels(hotelsData);
      setLoading(false);
    }, (error) => {
      handleFirestoreError(error, OperationType.LIST, "hotels_group");
      setLoading(false);
    });
    return () => unsubscribe();
  }, []);

  const filteredHotels = useMemo(() => {
    return hotels.filter(hotel => {
      const matchesDestination = !destination || 
        hotel.name.toLowerCase().includes(destination.toLowerCase()) || 
        hotel.city.toLowerCase().includes(destination.toLowerCase()) ||
        hotel.location.toLowerCase().includes(destination.toLowerCase());
      
      const matchesPrice = hotel.price >= priceRange[0] && hotel.price <= priceRange[1];
      const matchesRating = hotel.rating >= minRating;
      
      return matchesDestination && matchesPrice && matchesRating;
    });
  }, [hotels, destination, priceRange, minRating]);

  return (
    <div className="min-h-screen bg-[#f3f6f7]">
      {/* Mini Search Header */}
      <div className="bg-primary py-4 sticky top-16 z-40">
        <div className="container mx-auto px-4 flex gap-2">
            <div className="flex-1 bg-white rounded-sm flex items-center px-4 py-2 border border-accent ring-2 ring-accent shadow-sm">
                <Search size={18} className="text-gray-400 ml-2" />
                <input type="text" value={destination} onChange={(e) => setDestination(e.target.value)} className="bg-transparent outline-none w-full text-sm font-bold" />
            </div>
            <div className="flex-1 bg-white rounded-sm flex items-center px-4 py-2 border border-accent ring-2 ring-accent shadow-sm">
                <CalendarIcon size={18} className="text-gray-400 ml-2" />
                <span className="text-sm font-bold truncate">
                    {date.from ? format(date.from, "d MMM", { locale: ar }) : "تاريخ الوصول"} — {date.to ? format(date.to, "d MMM", { locale: ar }) : "تاريخ المغادرة"}
                </span>
            </div>
            <div className="flex-1 bg-white rounded-sm hidden md:flex items-center px-4 py-2 border border-accent ring-2 ring-accent shadow-sm">
                <Users size={18} className="text-gray-400 ml-2" />
                <span className="text-sm font-bold truncate">{guestCount}</span>
            </div>
            <Button className="bg-secondary text-white font-bold px-8 h-full">بحث</Button>
        </div>
      </div>

      <div className="container mx-auto px-4 grid grid-cols-1 lg:grid-cols-12 gap-6 mt-6 pb-20">
        {/* Filters Sidebar */}
        <aside className="lg:col-span-3 space-y-4">
          <div className="bg-white border border-border rounded-md p-4 sticky top-44">
            <h3 className="text-base font-bold mb-4 border-b pb-2">التصفية حسب:</h3>
            
            <div className="space-y-6">
              <div className="space-y-3">
                <p className="text-sm font-bold">ميزانيتك (لليلة الواحدة)</p>
                <div className="space-y-2">
                  {[
                    { label: "0 - 1,000 EGP", range: [0, 1000] },
                    { label: "1,000 - 2,500 EGP", range: [1000, 2500] },
                    { label: "2,500 - 5,000 EGP", range: [2500, 5000] },
                    { label: "5,000+ EGP", range: [5000, 10000] },
                  ].map((p, i) => (
                    <label key={i} className="flex items-center gap-3 cursor-pointer group">
                      <Checkbox 
                        onCheckedChange={() => setPriceRange(p.range as [number, number])}
                        checked={priceRange[0] === p.range[0] && priceRange[1] === p.range[1]}
                      />
                      <span className="text-sm group-hover:text-secondary transition-colors">{p.label}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div className="space-y-3">
                <p className="text-sm font-bold">تقييم النزلاء</p>
                <div className="space-y-2">
                  {[
                    { label: "ممتاز: +9", value: 9 },
                    { label: "جيد جداً: +8", value: 8 },
                    { label: "جيد: +7", value: 7 },
                    { label: "مرضي: +6", value: 6 },
                  ].map((r, i) => (
                    <label key={i} className="flex items-center gap-3 cursor-pointer group">
                      <Checkbox 
                        onCheckedChange={() => setMinRating(r.value)}
                        checked={minRating === r.value}
                      />
                      <span className="text-sm group-hover:text-secondary transition-colors">{r.label}</span>
                    </label>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </aside>

        {/* Main Results Area */}
        <main className="lg:col-span-9">
          <div className="mb-4">
            <h2 className="text-2xl font-bold">{destination || "كل المواقع"}: تم العثور على {filteredHotels.length} مكان إقامة</h2>
          </div>

          <div className="flex items-center gap-1 mb-6 border border-border rounded-md overflow-hidden bg-white shadow-sm scrollbar-hide overflow-x-auto">
            {["الأكثر رواجاً", "السعر (الأقل أولاً)", "عدد النجوم", "الأعلى تقييماً"].map((tab, i) => (
              <button 
                key={i} 
                className={cn(
                  "px-6 py-4 text-sm font-bold whitespace-nowrap border-l last:border-l-0 transition-colors",
                  i === 0 ? "bg-secondary text-white border-secondary" : "hover:bg-gray-50"
                )}
              >
                {tab}
              </button>
            ))}
          </div>

          {loading ? (
             <div className="flex justify-center py-40">
                <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
             </div>
          ) : (
            <div className="space-y-4">
              {filteredHotels.map((hotel) => (
                <Card key={hotel.id} className="booking-card flex flex-col md:flex-row h-full md:h-[280px]">
                  <div className="w-full md:w-[240px] lg:w-[300px] h-64 md:h-auto relative shrink-0">
                    <img src={hotel.images[0]} alt={hotel.name} className="w-full h-full object-cover" />
                    <button className="absolute top-3 right-3 p-2 bg-white/80 rounded-full hover:bg-white transition-colors">
                        <Heart size={20} className="text-red-500" />
                    </button>
                  </div>
                  
                  <div className="flex-grow p-4 flex flex-col">
                    <div className="flex justify-between items-start">
                      <div className="space-y-1">
                        <div className="flex items-center gap-2">
                           <h3 className="text-xl font-bold text-secondary hover:underline cursor-pointer" onClick={() => navigate(`/hotel/${hotel.id}`)}>{hotel.name}</h3>
                           <div className="flex items-center gap-0.5 text-[#ffb700]">
                              <Star size={14} className="fill-current" />
                              <Star size={14} className="fill-current" />
                              <Star size={14} className="fill-current" />
                              <Star size={14} className="fill-current" />
                           </div>
                        </div>
                        <div className="flex items-center gap-2 text-xs text-secondary font-bold underline cursor-pointer">
                          <MapPin size={12} />
                          <span>{hotel.city}، {hotel.location}</span>
                          <span className="text-gray-400 no-underline">• 8.5 كم من المركز</span>
                        </div>
                      </div>
                      
                      <div className="flex items-center gap-2 text-left">
                        <div className="leading-tight">
                          <p className="font-bold text-sm">ممتاز</p>
                          <p className="text-[11px] text-gray-500">{hotel.reviewsCount} تقييم</p>
                        </div>
                        <div className="bg-primary text-white font-bold text-lg w-9 h-9 flex items-center justify-center rounded-t-lg rounded-br-lg">
                          {hotel.rating.toFixed(1)}
                        </div>
                      </div>
                    </div>

                    <div className="mt-2 text-[11px] font-bold text-[#008009] flex items-center gap-1">
                      <Check size={12} />
                      إلغاء مجاني • لا حاجة للدفع مسبقاً
                    </div>

                    <p className="text-xs text-gray-600 line-clamp-2 mt-4 leading-relaxed">
                      {hotel.description}
                    </p>

                    <div className="mt-auto flex justify-end items-end gap-4 border-r-0 md:border-r border-border pl-0 md:pr-6">
                      <div className="text-left">
                        <p className="text-[11px] text-gray-500 font-medium">3 ليالٍ، 2 بالغين</p>
                        <div className="flex items-baseline gap-1">
                          <span className="text-xs font-bold line-through text-red-500">EGP {Math.round(hotel.price * 1.2)}</span>
                          <span className="text-2xl font-black text-foreground tracking-tighter">EGP {hotel.price * 3}</span>
                        </div>
                        <p className="text-[10px] text-gray-500">+ EGP 450 ضرائب ورسوم</p>
                      </div>
                      <Button 
                        onClick={() => navigate(`/hotel/${hotel.id}?from=${date.from?.toISOString()}&to=${date.to?.toISOString()}`)}
                        className="bg-secondary text-white font-bold px-8 h-12 rounded-sm"
                      >
                        عرض التوافر <ChevronLeft className="mr-1" size={18} />
                      </Button>
                    </div>
                  </div>
                </Card>
              ))}
            </div>
          )}
        </main>
      </div>
    </div>
  );
}
