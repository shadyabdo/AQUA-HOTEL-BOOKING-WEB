rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 1. مساعدات التحقق (Helpers) ---
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email.lower() == "otdragoze@gmail.com" || 
              request.auth.token.email.lower() == "shadyabdowd2020@gmail.com");
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isVerifiedUser() {
      return isSignedIn();
    }

    // --- 2. قواعد البحث الشامل (Collection Group) ---
    // هذه القواعد ضرورية لعمل الفنادق والغرف في القائمة الجانبية واللوحة الشاملة
    match /{path=**}/hotels/{hotelId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /{path=**}/Hotels/{hotelId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /{path=**}/hotel/{hotelId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /{path=**}/rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /{path=**}/Rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /{path=**}/room/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // دعم القراءة الشاملة للمحتوى العام
    match /{path=**}/articles/{id} { allow read: if true; }
    match /{path=**}/coupons/{id} { allow read: if true; }
    match /{path=**}/ads/{id} { allow read: if true; }

    // --- 3. قاعدة اختبار الاتصال ---
    match /_connection_test/{docId} {
      allow read: if true;
    }
    
 

    // --- 4. قواعد الفنادق والغرف والتقييمات ---
    // قاعدة عامة للتعامل مع الفنادق في أي مسار (سواء تحت المدن أو في المستوى الأعلى)
    match /{path=**}/hotels/{hotelId} {
      allow read: if true;
      allow update: if isSignedIn(); // للسماح بتحديث الـ rating والـ reviewsCount
      allow write: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }
    
    // دعم الأسماء البديلة (Hotels, hotel, Room, etc.)
    match /{path=**}/Hotels/{id} { allow read: if true; allow write: if isAdmin(); }
    match /{path=**}/rooms/{id} { allow read: if true; allow write: if isAdmin(); }
    match /{path=**}/Rooms/{id} { allow read: if true; allow write: if isAdmin(); }

    // --- 5. قواعد المقالات والتعليقات ---
    match /{path=**}/articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
      match /feedback/{feedbackId} {
        allow read, write, create, list: if true;
      }
    }
    
    match /{path=**}/Articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
      match /feedback/{feedbackId} {
        allow read, write, create, list: if true;
      }
    }

    // --- 6. ملفات المستخدمين وحجوزاتهم ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      match /transactions/{transactionId} {
        allow read, create, list: if isSignedIn() && request.auth.uid == userId;
      }
      match /favorites/{favoriteId} {
        allow read, write, create, list: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn(); // السماح للمستخدمين برؤية الحجوزات للتحقق من التوفر (Availability Check)
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- 7. الكوبونات والإعلانات ---
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- 7. القاعدة العامة (إغلاق كل شيء آخر) ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
