rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // 1. Helpers
    // =========================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             (
               request.auth.token.email.lower() == "otdragoze@gmail.com" ||
               request.auth.token.email.lower() == "shadyabdowd2020@gmail.com" ||
               request.auth.token.email.lower() == "gidehotel@gmail.com" ||
               request.auth.token.email.lower() == "abdo20004044@gmail.com"
             );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // =========================
    // 2. Global Collection Group
    // =========================

    // Hotels (موحد + فيه reviews)
    match /{path=**}/hotels/{hotelId} {
      allow read: if true;
      allow update: if isSignedIn(); // للسماح بتحديث التقييمات
      allow write: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }

    // Rooms
    match /{path=**}/rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // دعم أسماء collections المختلفة بدون تكرار
    match /{path=**}/{col}/{id} {
      allow read: if col in ['hotels', 'Hotels', 'hotel', 'Hotel', 'rooms', 'Rooms', 'room', 'Room', 'articles', 'Articles'];
      allow write: if isAdmin() && col in ['hotels', 'Hotels', 'hotel', 'Hotel', 'rooms', 'Rooms', 'room', 'Room', 'articles', 'Articles'];
    }

    // محتوى عام
    match /{path=**}/articles/{id} { allow read: if true; }
    match /{path=**}/coupons/{id} { allow read: if true; }
    match /{path=**}/ads/{id} { allow read: if true; }

    // =========================
    // 3. Connection Test
    // =========================
    match /_connection_test/{docId} {
      allow read: if true;
    }

    // =========================
    // 4. Structured Data (cities)
    // =========================
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();

      match /hotels/{hotelId} {
        allow read: if true;
        allow write: if isAdmin();

        match /rooms/{roomId} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }

    // =========================
    // 5. Bookings
    // =========================
    match /bookings/{bookingId} {
      allow read: if true; // للسماح بالتحقق من التوفر للجميع
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // =========================
    // 6. Users
    // =========================
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      match /transactions/{transactionId} {
        allow read, create: if isSignedIn() && request.auth.uid == userId;
      }

      match /favorites/{favoriteId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // =========================
    // 7. Articles + Comments + Feedback
    // =========================
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }

      match /feedback/{feedbackId} {
        allow read, write: if true;
      }
    }

    // دعم اسم الكولكشن الكبير
    match /Articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
      
      match /feedback/{feedbackId} {
        allow read, write: if true;
      }
    }

    // =========================
    // 8. Coupons
    // =========================
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =========================
    // 9. Ads
    // =========================
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =========================
    // 10. Fallback
    // =========================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}