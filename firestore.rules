rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // 1. Helpers
    // =========================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email_verified == true &&
             (
               request.auth.token.email.lower() == "otdragoze@gmail.com" ||
               request.auth.token.email.lower() == "shadyabdowd2020@gmail.com" ||
               request.auth.token.email.lower() == "gidehotel@gmail.com" ||
               request.auth.token.email.lower() == "abdo20004044@gmail.com"
             );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // =========================
    // 2. Global Collection Group
    // =========================

    // Hotels (موحد + فيه reviews)
    match /{path=**}/hotels/{hotelId} {
      allow read: if true;

      // ⚠️ مفتوحة حاليًا - يفضل تقييدها لاحقًا
      allow update: if isSignedIn();

      allow write: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || isOwner(resource.data.userId);
      }
    }

    // Rooms (موحد)
    match /{path=**}/rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // دعم أسماء collections المختلفة بدون تكرار
    match /{path=**}/{col}/{id} {
      allow read: if col in ['Hotels', 'hotel', 'Rooms', 'room'];
      allow write: if isAdmin() && col in ['Hotels', 'hotel', 'Rooms', 'room'];
    }

    // محتوى عام
    match /{path=**}/articles/{id} { allow read: if true; }
    match /{path=**}/coupons/{id} { allow read: if true; }
    match /{path=**}/ads/{id} { allow read: if true; }

    // =========================
    // 3. Connection Test
    // =========================
    match /_connection_test/{docId} {
      allow read: if true;
    }

    // =========================
    // 4. Structured Data (cities)
    // =========================
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();

      match /hotels/{hotelId} {
        allow read: if true;
        allow write: if isAdmin();

        match /rooms/{roomId} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }

    // =========================
    // 5. Bookings (نسخة آمنة)
    // =========================
    match /bookings/{bookingId} {

      allow read: if isSignedIn() &&
                   (isOwner(resource.data.userId) || isAdmin());

      allow create: if isSignedIn()
                    && request.auth.token.email_verified == true
                    && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() &&
                     (isOwner(resource.data.userId) || isAdmin());

      allow delete: if isAdmin();
    }

    // =========================
    // 6. Users
    // =========================
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create, write: if isOwner(userId);

      match /transactions/{transactionId} {
        allow read, create: if isOwner(userId);
      }

      match /favorites/{favoriteId} {
        allow read, write: if isOwner(userId);
      }
    }

    // =========================
    // 7. Articles + Comments + Feedback
    // =========================
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || isOwner(resource.data.userId);
      }

      match /feedback/{feedbackId} {
        allow read, write: if true;
      }
    }

    match /Articles/{articleId} {
      allow read: if true;

      allow create: if isAdmin()
        && request.resource.data.keys().hasAll(['عنوان المقالة', 'محتوى المقالة'])
        && request.resource.data['محتوى المقالة'] is string
        && (!request.resource.data.keys().hasAny(['التصنيفات']) ||
            request.resource.data['التصنيفات'] is list);

      allow update: if isAdmin()
        && (!request.resource.data.keys().hasAny(['محتوى المقالة']) ||
            request.resource.data['محتوى المقالة'] is string)
        && (!request.resource.data.keys().hasAny(['التصنيفات']) ||
            request.resource.data['التصنيفات'] is list);

      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || isOwner(resource.data.userId);
      }

      match /feedback/{feedbackId} {
        allow read, write: if true;
      }
    }

    // =========================
    // 8. Coupons
    // =========================
    match /coupons/{couponId} {
      allow read: if true;

      allow create, update: if isAdmin()
        && request.resource.data.keys().hasAll(['code', 'discountPercentage', 'isActive']);

      allow delete: if isAdmin();
    }

    // =========================
    // 9. Ads
    // =========================
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =========================
    // 10. Fallback
    // =========================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}