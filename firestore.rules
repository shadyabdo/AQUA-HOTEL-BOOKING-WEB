rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() &&
             (request.auth.token.email.lower() in [
               "otdragoze@gmail.com", 
               "shadyabdowd2020@gmail.com", 
               "gidehotel@gmail.com", 
               "abdo20004044@gmail.com"
             ]);
    }

    // 1. القواعد العامة للقراءة (مفتوحة للجميع لضمان ظهور البيانات)
    match /{path=**}/hotels/{id} { allow read: if true; }
    match /{path=**}/Hotels/{id} { allow read: if true; }
    match /{path=**}/hotel/{id} { allow read: if true; }
    match /{path=**}/rooms/{id} { allow read: if true; }
    match /{path=**}/Rooms/{id} { allow read: if true; }
    match /{path=**}/room/{id} { allow read: if true; }
    match /{path=**}/Room/{id} { allow read: if true; }
    match /{path=**}/cities/{id} { allow read: if true; }
    match /{path=**}/Cities/{id} { allow read: if true; }
    match /{path=**}/articles/{id} { allow read: if true; }
    match /{path=**}/Articles/{id} { allow read: if true; }
    match /{path=**}/coupons/{id} { allow read: if true; }
    match /{path=**}/ads/{id} { allow read: if true; }

    // 2. تحديث البيانات العامة (للأدمن أو العمليات التفاعلية)
    match /{path=**}/hotels/{hotelId} {
      allow update: if isSignedIn();
      allow write: if isAdmin();
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }
    match /{path=**}/articles/{articleId} {
      allow write: if isAdmin();
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
      match /feedback/{feedbackId} { allow read, write: if true; }
    }
    match /{path=**}/Articles/{articleId} {
      allow write: if isAdmin();
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
      match /feedback/{feedbackId} { allow read, write: if true; }
    }

    // 3. الحجوزات (مفتوحة للقراءة لضمان التحقق من التوفر)
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 4. المستخدمين والمحفظة (خاصة بكل مستخدم)
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      match /transactions/{transactionId} {
        allow read, create: if isSignedIn() && request.auth.uid == userId;
      }
      match /favorites/{favoriteId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // القاعدة الاحتياطية
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}